{
  "name": "fut7",
  "version": "0.1.0",
  "description": "Plataforma multi-time para organizar atletas, agendas, presenças, súmulas e estatísticas.",
  "private": true,
  "engines": {
    "node": "24.x",
    "npm": ">=11 <12"
  },
  "packageManager": "npm@11.17.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:lint": "supabase db lint --level warning",
    "db:test": "supabase test db",
    "db:types": "supabase gen types typescript --local > lib/database.types.ts",
    "security:audit": "npm audit --audit-level=moderate",
    "verify": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@radix-ui/react-label": "2.1.11",
    "@radix-ui/react-slot": "1.3.0",
    "@supabase/ssr": "0.12.1",
    "@supabase/supabase-js": "2.110.3",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "0.511.0",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "server-only": "0.0.1",
    "tailwind-merge": "3.6.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "10.5.2",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "postcss": "8.5.19",
    "supabase": "2.109.1",
    "tailwindcss": "3.4.19",
    "tailwindcss-animate": "1.0.7",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  },
  "overrides": {
    "postcss": "8.5.19"
  },
  "allowScripts": {
    "sharp@0.34.5": true,
    "unrs-resolver@1.12.2": true,
    "fsevents": false
  }
}
