# Safe for the browser. Use the publishable key, never service_role.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Server-only elevated key. It bypasses RLS and may only be imported from
# server-only modules. New hosted projects use the sb_secret_... format.
SUPABASE_SECRET_KEY=your-secret-key

# Canonical application URL used for validated redirects and metadata.
APP_URL=http://localhost:3000

# Required before enabling anonymous athlete registration in production.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
